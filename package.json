{
  "name": "app-de-pedidos-delivery",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n api,vite -c blue,green \"npm run server\" \"npm run dev\"",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "server": "node server/index.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.3",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.1.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^3.1.4"
  }
}
