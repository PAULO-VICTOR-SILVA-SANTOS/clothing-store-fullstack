# Copie para .env na raiz do projeto (API lê daqui; Vite também pode ler variáveis VITE_* do mesmo arquivo).

# --- API (Node) ---
MONGODB_URI=mongodb://127.0.0.1:27017/castro_pedidos
PORT=3000
# Opcional: URLs absolutas retornadas no POST /upload (ex.: https://api.sualoja.com)
PUBLIC_API_URL=
# Opcional: se definida, POST/PATCH/DELETE produtos, POST /upload e GET /pedidos exigem header x-admin-key
# (ou Bearer com o mesmo valor; ou JWT emitido por POST /auth/login se JWT_SECRET estiver definida)
ADMIN_API_KEY=
# Opcional: assinatura dos tokens JWT (recomendado em produção). Com JWT_SECRET, o painel pode usar POST /auth/login
# em vez de colocar a chave no bundle (VITE_ADMIN_API_KEY).
JWT_SECRET=
# Opcional: senha só para login JWT (POST /auth/login). Se vazio, o login usa a mesma string que ADMIN_API_KEY.
ADMIN_PASSWORD=

# Opcional: URL do Cloudinary (upload vai para a nuvem em vez de server/uploads)
# Ex.: CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=
# Pasta lógica no Cloudinary (opcional)
CLOUDINARY_UPLOAD_FOLDER=castro-pedidos

# Limite de POST /pedidos por IP a cada 15 min (padrão 45)
PEDIDOS_RATE_MAX=45

# Helmet (CSP e outros cabeçalhos na API). O Vite continua em outra origem — não serve HTML pela API.
# HELMET_DISABLE=true desliga tudo (só se precisar depurar).
# HELMET_HSTS=false desliga Strict-Transport-Security mesmo em NODE_ENV=production.
HELMET_DISABLE=
HELMET_HSTS=

# Testes: `npm test` (Vitest + MongoDB em memória; não precisa de .env para rodar).

# --- Front (Vite) — mesmo arquivo .env na raiz ---
# Deve ser IGUAL a ADMIN_API_KEY quando você proteger a API (só para painel admin / gestão).
# Preferível em produção: deixe vazio e use "Entrar na API" no painel (JWT), sem expor a chave no front.
VITE_ADMIN_API_KEY=
